# Application
NODE_ENV=development
APP_NAME=Pennylane Premium OS
APP_URL=http://localhost:3000
APP_PORT=3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pennylane_dev
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TTL=86400

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage
S3_BUCKET=pennylane-dev
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pennylane-os.local

# Payment
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# IA/ML
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=pennylane-group

# Monitoring
SENTRY_DSN=
LOG_LEVEL=debug

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
SECURE_COOKIES=false
